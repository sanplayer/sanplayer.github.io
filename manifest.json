{
  "name": "SanPlayer",
  "short_name": "SanPlayer",
  "id": "/",
  "description": "Suas músicas, sua experiência. O San Player traz o design intuitivo e a fluidez que você ama, agora com total controle das suas playlists em um ambiente rápido e sem distrações.",
  "start_url": "/",
  "scope": "/",
  "display_override": [
    "window-controls-overlay",
    "standalone"
  ],
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0F0D12",
  "theme_color": "#0F0D12",
  "categories": [
    "music",
    "multimedia"
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "file_handlers": [
    {
      "action": "/index.html",
      "accept": {
        "audio/*": [".mp3", ".wav", ".ogg", ".m4a"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+sanplayer",
      "url": "/index.html?action=%s"
    }
  ],
  "screenshots": [
    {
      "src": "screenshots/tela1.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow"
    },
    {
      "src": "screenshots/tela2.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow"
    },
    {
      "src": "screenshots/tela3.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow"
    },
    {
      "src": "screenshots/screenshot-wide.jpg",
      "sizes": "1920x1080",
      "type": "image/jpeg",
      "form_factor": "wide"
    }
  ],
  "icons": [
    {
      "src": "icons/icon192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/icon512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=io.github.sanplayer.twa",
      "id": "io.github.sanplayer.twa"
    }
  ],
  "prefer_related_applications": true,
  "shortcuts": [
    {
      "name": "Playlists",
      "short_name": "Playlists",
      "description": "Acesse suas playlists salvas",
      "url": "index.html?modal=playlists",
      "icons": [
        {
          "src": "shortcuts/playlist.png",
          "sizes": "128x128",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Artistas",
      "short_name": "Artistas",
      "description": "Veja seus artistas favoritos",
      "url": "index.html?modal=artists",
      "icons": [
        {
          "src": "shortcuts/artist.png",
          "sizes": "128x128",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Favoritos",
      "short_name": "Favoritos",
      "description": "Suas músicas favoritas",
      "url": "index.html?modal=favorites",
      "icons": [
        {
          "src": "shortcuts/favorite.png",
          "sizes": "128x128",
          "type": "image/png"
        }
      ]
    }
  ],
  "dir": "auto",
  "lang": "pt-BR"
}
