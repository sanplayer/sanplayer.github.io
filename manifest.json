{
  "name": "SanPlayer",
  "short_name": "SanPlayer",
  "id": "sanplayer-v1.3.7",
  "description": "Player de músicas personalizado com experiência estilo YouTube Music. Acesse suas playlists, artistas favoritos e músicas em qualquer lugar.",
  "start_url": "index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0f0f0f",
  "theme_color": "#0f0f0f",
  "categories": [
    "music",
    "multimedia"
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "file_handlers": [
    {
      "action": "index.html",
      "accept": {
        "audio/*": [".mp3", ".wav", ".ogg", ".m4a"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+sanplayer",
      "url": "index.html?action=%s"
    }
  ],
  "screenshots": [
    {
      "src": "screenshots/tela1.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow"
    },
    {
      "src": "screenshots/tela2.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow"
    },
    {
      "src": "screenshots/tela3.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow"
    },
    {
      "src": "screenshots/screenshot-wide.jpg",
      "sizes": "1920x1080",
      "type": "image/jpeg",
      "form_factor": "wide"
    }
  ],
  "icons": [
    {
      "src": "icons/icon192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "prefer_related_applications": false,
  "shortcuts": [
    {
      "name": "Playlists",
      "short_name": "Playlists",
      "description": "Acesse suas playlists salvas",
      "url": "index.html?modal=playlists",
      "icons": [
        {
          "src": "shortcuts/playlist.png",
          "sizes": "128x128",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Artistas",
      "short_name": "Artistas",
      "description": "Veja seus artistas favoritos",
      "url": "index.html?modal=artists",
      "icons": [
        {
          "src": "shortcuts/artist.png",
          "sizes": "128x128",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Favoritos",
      "short_name": "Favoritos",
      "description": "Suas múscas favoritas",
      "url": "index.html?modal=favorites",
      "icons": [
        {
          "src": "shortcuts/heart.png",
          "sizes": "128x128",
          "type": "image/png"
        }
      ]
    }
  ],
  "dir": "auto",
  "lang": "pt",
  "display_override": [
    "window-controls-overlay",
    "standalone"
  ]
}